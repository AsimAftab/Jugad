#include<stdio.h>
#include<stdlib.h>
#include<time.h>

void swap(int *a,int *b)
{
    int temp=*a;
    *a=*b;
    *b=temp;

}

int partition(int a[],int low,int high)
{
    int pivot=a[low],leftPointer=low,rightPointer=high;
    do {
        do {
            leftPointer++;

        }while(a[leftPointer]<pivot &&leftPointer<high);
        do{
            rightPointer--;

        }while(a[rightPointer]>pivot);
        if(leftPointer<rightPointer){
            swap(&a[leftPointer],&a[rightPointer]);
        }
    }while(leftPointer<rightPointer);
    swap(&a[rightPointer],&a[low]);
    return rightPointer;


}

void quickSort(int a[],int low,int high)
{
    int mid;
    if(low<high)
    {
        mid= partition(a,low,high);
        quickSort(a,low,mid-1);
        quickSort(a,mid+1,high);
    }
}

void calc(int a[],int low,int high)
{
    clock_t start,end;
    double time;
    start=clock();
    quickSort(a,low,high);
    end=clock();
    time=((double )(end-start))/CLOCKS_PER_SEC;
    printf("\t%f",time);
}

int main()
{
    int i,j,n=10000,k=1;
    printf("Ascending Order\tRandom Number\tDescending Order");
    while(k<5)
    {
        int a[n];
        printf("\n\t %d",n);
        for(i=0;i<n;i++)
            a[i]=i;
        calc(a,0,n-1);
        for(i=0;i<n;i++)
            a[i]=rand()%(n*10);
        calc(a,0,n-1);
        for(j=0,i=n;i>0;i--,j++)
            a[j]=i;
        calc(a,0,n-1);
        n=n*2;
        k++;
    }
}
