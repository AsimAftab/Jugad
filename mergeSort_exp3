#include<stdio.h>
#include<stdlib.h>
#include<time.h>

void Merge(int low,int mid,int high,int a[],int b[])
{
    int l=low,i=low,r=mid+1,k;
    while((l<=mid)&&(r<=high))
    {
        if(a[l]<a[r])
        {
            b[i]=a[l];
            l++;
        }
        else
        {
            b[i]=a[r];
            r++;
        }
        i++;
    }
    if(l>mid)
    {
        for(k=r;k<=high;k++)
        {
            b[i++]=a[k];
        }
    }
    else
    {
        for(k=l;k<=mid;k++)
        {
            b[i++]=a[k];
        }
    }
    for(k=low;k<=high;k++)
        a[k]=b[k];
}

void mergeSort(int low,int high,int a[],int b[])
{
    int mid;
    if(low<high)
    {
        mid=(low+high)/2;
        mergeSort(low,mid,a,b);
        mergeSort(mid+1,high,a,b);
        Merge(low,mid,high,a,b);
    }
}

void calc(int low,int high,int a[],int b[])
{
    clock_t start,end;
    double time;
    start=clock();
    mergeSort(low,high,a,b);
    end=clock();
    time=((double )(end-start))/CLOCKS_PER_SEC;
    printf("\t%f",time);

}


int main()
{
    int i,j,n=10000,k=1;
    printf("Ascending Order\tRandom Number\tDescending Order");
    while(k<5)
    {
        int a[n],b[n];
        printf("\n\t%d",n);
        for(i=0;i<n;i++)
            a[i]=i;
        calc(0,n-1,a,b);
        for(i=0;i<n;i++)
            a[i]=rand()%(n*10);
        calc(0,n-1,a,b);
        for(j=0,i=n;i>0;i--,j++)
            a[j]=i;
        calc(0,n-1,a,b);
        n=n*2;
        k++;

    }
}
