#include<stdio.h>
#include<time.h>
#include<stdlib.h>

void swap(int *a,int *b)
{
    int temp=*a;
    *a=*b;
    *b=temp;
}

void selectionSort(int a[],int n)
{
    int i,j,minIndex;
    for(i=0;i<n-1;i++)
    {
        minIndex=i;
        for(j=0;j<n;j++)
        {
            minIndex=j;
        }
        if(minIndex!=i)
            swap(&a[i],&a[minIndex]);
    }
}


void calc(int a[],int n)
{
    clock_t start,end;
    double time;
    start=clock();
    selectionSort(a,n);
    end=clock();
    time=((double)(end-start))/CLOCKS_PER_SEC;
    printf("\t%f",time);
}

int main()
{
    int i,j,n=10000,k=1;
    printf("Input\t Ascending order\t Random Number\t Descending Order");
    while(k<5)
    {
        int a[n];
        printf("\n\t%d",n);
        for(i=0;i<n;i++)
            a[i]=i;
        calc(a,n);
        for(i=0;i<n;i++)
            a[i]=rand()%(n*10);
        calc(a,n);
        for(j=0,i=n;i>0;j++,i--)
            a[j]=i;
        calc(a,n);
        n=n*2;
        k++;
    }
}

