#include<stdio.h>
#include<math.h>

int x[20],count=1;
void queen(int,int );
int place(int,int);

int main()
{
    int n,k=1;
    printf("\nEnter the no of queens to be placed: ");
    scanf("%d",&n);
    queen(k,n);
    return 0;

}

void queen(int k,int n)
{
    int i,j;
    for(j=1;j<=n;j++)
    {
        if(place(k,j))
        {
            x[k]=j;
            if(k==n)
            {
                printf("\n%d Solution",count);
                count++;
                for(i=1;i<=n;i++)
                    printf("\n \t%d row <--> %d column",i,x[i]);
            }
            else
            {
                queen(k+1,n);
            }
        }
    }
}

int place(int k,int j)
{
    int i;
    for(i=1;i<k;i++)
    {
        if((x[i]==j) || (abs(x[i]-j)==(abs(i-k))))
            return 0;
    }
    return 1;
}
