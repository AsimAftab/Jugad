#include<stdio.h>
int v[10][10],w[10],p[10];
int n,m;
int max(int a,int b)
{
    return (a>b)?a:b;

}

void knapsack()
{
    int i,j;
    for(i=0;i<=n;i++)
    {
        for(j=0;j<=m;j++)
        {
            if(i==0 || j==0)
            {
                v[i][j]=0;
            }
            else if(w[i]>j)
            {
                v[i][j]=v[i-1][j];
            }
            else{
                v[i][j]=max(v[i-1][j],v[i-1][j-w[i]]+p[i]);
            }
        }
    }
}

int main()
{
    int i,j;
    printf("\nEnter the knapsack capacity: ");
    scanf("%d",&m);
    printf("\nEnter the no of objects: ");
    scanf("%d",&n);
    printf("\nEnter the profits: ");
    for(i=1;i<=n;i++)
    {
        scanf("%d",&p[i]);
    }
    printf("\nEnter the weights: ");
    for(i=1;i<=n;i++)
    {
        scanf("%d",&w[i]);
    }
    knapsack();
    for(i=0;i<=n;i++) {
        for (j = 0; j <= m; j++) {
            printf("%d\t",v[i][j]);
        }
        printf("\n");
    }
}
