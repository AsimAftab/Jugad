set serveroutput on;
create table employee(
e_id number(10),
e_name char(20),
age number(2),
salary number(10,2)
);

//insert 4 values using
insert into employee values(&e_id,'&ename',&age,&salary);

declare
	cursor c1 is
	select e_id,e_name,age,salary
	from employee;
	id employee.e_id%type;
	name employee.e_name%type;
	e_age employee.age%type;
	e_salary employee.salary%type;
	begin
		open c1;
		loop
			fetch c1 into id,name,e_age,e_salary;	
			exit when c1%NOTFOUND;
			dbms_output.put_line(id ||'	'|| name ||'	'|| e_age ||'	'|| e_salary);
		end loop;	
		close c1;
end; 
