Salary number(10,2)
);

//insert 2/3 values
Insert into customer values(&id,’&name’,&age,’&address’,&salary);

//creating triggers
create or replace trigger display_sal_changes
before insert or delete or update
on customer
for each row
declare
	sal_diff number;
begin
	if inserting then
		dbms_output.put_line('inserting row');
		dbms_output.put_line('new salary:' || :new.salary);
	elsif updating then
		sal_diff:=:new.salary-:old.salary;
		dbms_output.put_line('Old salary:' || :old.salary);
		dbms_output.put_line('new salary:' || :new.salary);
		dbms_output.put_line('sal diff:' || sal_diff);
	elsif deleting then
		dbms_output.put_line('Deleting row');
		dbms_output.put_line('old salary:' || :old.salary);
	end if;
end;


